# SentryMode — environment variables
#
# Runtime settings are loaded via pydantic-settings with prefix SENTRYMODE_.
# Copy this file to `.env` and uncomment or set values as needed.
#
# VIX Yahoo data sources (defaults):
#   VIX: ^VIX
#   SPY: SPY
#   Period: 1y

# -----------------------------------------------------------------------------
# Common
# -----------------------------------------------------------------------------

# Bark endpoint for push notifications (required; non-empty after trim).
# SENTRYMODE_BARK_SERVER=https://api.day.app
# SENTRYMODE_BARK_DEVICE_KEY=your_device_key

# Polling interval for the shared monitor loop (seconds).
# Default: 60
# SENTRYMODE_POLL_INTERVAL_SECONDS=60

# Enabled factors as a JSON array string. `ai_portfolio`, `vix`, `us10y`, and `btc_realized_pl_ratio_90d`
# are registered but not enabled by default.
# Default: ["ahr999"]
# SENTRYMODE_ENABLED_FACTORS=["ahr999"]

# Report rendering format and language.
# Defaults: markdown / en
# SENTRYMODE_REPORT_FORMAT=markdown
# SENTRYMODE_REPORT_LANGUAGE=en

# Glassnode API settings for Glassnode-backed factors.
# Defaults: https://api.glassnode.com / empty / 10.0
# Leave the API key empty unless you enable a factor that requires Glassnode.
# SENTRYMODE_GLASSNODE_API_URL=https://api.glassnode.com
# SENTRYMODE_GLASSNODE_API_KEY=your_glassnode_api_key
# SENTRYMODE_GLASSNODE_HTTP_TIMEOUT_SECONDS=10.0

# -----------------------------------------------------------------------------
# AHR999
# -----------------------------------------------------------------------------

# Scheduled execution hour / minute / timezone for AHR999.
# Defaults: 9 / 20 / America/New_York
# SENTRYMODE_AHR_RUN_HOUR=9
# SENTRYMODE_AHR_RUN_MINUTE=20
# SENTRYMODE_AHR_RUN_TIMEZONE=America/New_York

# BTC genesis date used in the valuation curve (YYYY-MM-DD).
# Default: 2009-01-03
# SENTRYMODE_AHR_GENESIS_DATE=2009-01-03

# Fitted long-term valuation curve coefficients.
# Defaults: 5.8 / 16.88
# SENTRYMODE_AHR_FIT_A=5.8
# SENTRYMODE_AHR_FIT_B=16.88

# Number of daily closes required to compute AHR999.
# Default: 200
# SENTRYMODE_AHR_LOOKBACK_DAYS=200

# Kraken pair, candle interval (minutes), and OHLC API URL.
# Defaults: XBTUSD / 1440 / https://api.kraken.com/0/public/OHLC
# SENTRYMODE_AHR_KRAKEN_PAIR=XBTUSD
# SENTRYMODE_AHR_KRAKEN_INTERVAL_MINUTES=1440
# SENTRYMODE_AHR_KRAKEN_API_URL=https://api.kraken.com/0/public/OHLC

# HTTP timeout for BTC data fetching and Bark push (seconds).
# Default: 10.0
# SENTRYMODE_AHR_HTTP_TIMEOUT_SECONDS=10.0

# -----------------------------------------------------------------------------
# BTC Realized P/L Ratio (SMA90)
# -----------------------------------------------------------------------------

# Scheduled execution hour / minute / timezone for the BTC realized P/L ratio SMA90 factor.
# Defaults: 9 / 25 / America/New_York
# SENTRYMODE_BTC_REALIZED_PL_RATIO_90D_RUN_HOUR=9
# SENTRYMODE_BTC_REALIZED_PL_RATIO_90D_RUN_MINUTE=25
# SENTRYMODE_BTC_REALIZED_PL_RATIO_90D_RUN_TIMEZONE=America/New_York

# Daily history retained and SMA window used for cycle detection.
# Defaults: lookback 120, SMA 90, threshold 1.0
# SENTRYMODE_BTC_REALIZED_PL_RATIO_90D_LOOKBACK_DAYS=120
# SENTRYMODE_BTC_REALIZED_PL_RATIO_90D_SMA_WINDOW=90
# SENTRYMODE_BTC_REALIZED_PL_RATIO_90D_THRESHOLD=1.0

# -----------------------------------------------------------------------------
# VIX
# -----------------------------------------------------------------------------

# Scheduled execution hour / minute / timezone for the VIX factor.
# Defaults: 16 / 5 / America/New_York
# SENTRYMODE_VIX_RUN_HOUR=16
# SENTRYMODE_VIX_RUN_MINUTE=5
# SENTRYMODE_VIX_RUN_TIMEZONE=America/New_York

# Trading days retained for VIX/SPY calculations.
# Default: 60
# SENTRYMODE_VIX_LOOKBACK_DAYS=60

# VIX SMA / ROC windows.
# Defaults: 10 / 10
# SENTRYMODE_VIX_SMA_WINDOW=10
# SENTRYMODE_VIX_ROC_WINDOW=10

# Regime thresholds (VIX levels and ROC escalation).
# Defaults: yellow_min 15.0, green_max 18.0, red_min 20.0, blue_spike_min 30.0,
#           roc_yellow 0.15, roc_red 0.30
# SENTRYMODE_VIX_YELLOW_MIN=15.0
# SENTRYMODE_VIX_GREEN_MAX=18.0
# SENTRYMODE_VIX_RED_MIN=20.0
# SENTRYMODE_VIX_BLUE_SPIKE_MIN=30.0
# SENTRYMODE_VIX_ROC_YELLOW_THRESHOLD=0.15
# SENTRYMODE_VIX_ROC_RED_THRESHOLD=0.30

# Consecutive closes above SMA10 for yellow confirmation.
# Default: 2
# SENTRYMODE_VIX_TWO_DAY_CONFIRMATION=2

# SPY SMA window for confirmation.
# Default: 20
# SENTRYMODE_SPY_SMA_WINDOW=20

# Yahoo symbols and fetch period for VIX/SPY (`1y`, `2y`, `5y`, `max`, etc.).
# Defaults: ^VIX / SPY / 1y
# SENTRYMODE_VIX_YAHOO_SYMBOL=^VIX
# SENTRYMODE_SPY_YAHOO_SYMBOL=SPY
# SENTRYMODE_VIX_YAHOO_PERIOD=1y

# HTTP timeout for VIX/SPY data fetching and Bark push (seconds).
# Default: 10.0
# SENTRYMODE_VIX_HTTP_TIMEOUT_SECONDS=10.0

# -----------------------------------------------------------------------------
# AI Portfolio
# -----------------------------------------------------------------------------

# Scheduled execution hour / minute / timezone for the AI infrastructure portfolio factor.
# Defaults: 16 / 15 / America/New_York
# SENTRYMODE_PORTFOLIO_RUN_HOUR=16
# SENTRYMODE_PORTFOLIO_RUN_MINUTE=15
# SENTRYMODE_PORTFOLIO_RUN_TIMEZONE=America/New_York

# Yahoo history period used for QQQ / SMH / position tickers.
# Default: 2y
# SENTRYMODE_PORTFOLIO_YAHOO_PERIOD=2y

# Moving-average and breakout windows.
# Defaults: short 20, medium 50, long 200, breakout 10
# SENTRYMODE_PORTFOLIO_SHORT_WINDOW=20
# SENTRYMODE_PORTFOLIO_MEDIUM_WINDOW=50
# SENTRYMODE_PORTFOLIO_LONG_WINDOW=200
# SENTRYMODE_PORTFOLIO_BREAKOUT_WINDOW=10

# Earnings guard window in trading days before new adds are paused.
# Default: 5
# SENTRYMODE_PORTFOLIO_EARNINGS_GUARD_DAYS=5

# Market regime thresholds.
# Defaults: green<18.0, yellow/orange split 24.0, orange/red split 30.0, extreme>35.0
# SENTRYMODE_PORTFOLIO_VIX_GREEN_MAX=18.0
# SENTRYMODE_PORTFOLIO_VIX_YELLOW_MAX=24.0
# SENTRYMODE_PORTFOLIO_VIX_ORANGE_MAX=30.0
# SENTRYMODE_PORTFOLIO_VIX_EXTREME_MIN=35.0

# NLR-specific build guard.
# Default: 22.0
# SENTRYMODE_PORTFOLIO_NLR_VIX_BUILD_MAX=22.0

# Optional live position context used to switch alerts from BUILD to ADD and
# to determine whether a position is already profitable. Use JSON arrays/maps.
# SENTRYMODE_PORTFOLIO_CURRENT_POSITIONS=["GOOG","NVDA"]
# SENTRYMODE_PORTFOLIO_COST_BASIS={"GOOG":175.0,"NVDA":110.0}

# -----------------------------------------------------------------------------
# US10Y
# -----------------------------------------------------------------------------

# Scheduled execution hour / minute / timezone for the US10Y factor.
# Defaults: 16 / 10 / America/New_York
# SENTRYMODE_US10Y_RUN_HOUR=16
# SENTRYMODE_US10Y_RUN_MINUTE=10
# SENTRYMODE_US10Y_RUN_TIMEZONE=America/New_York

# Yahoo symbol and fetch period (`1y`, `2y`, `5y`, `max`, etc.).
# Defaults: ^TNX / 1y
# SENTRYMODE_US10Y_SYMBOL=^TNX
# SENTRYMODE_US10Y_YAHOO_PERIOD=1y

# Lookback and indicator windows.
# Defaults: lookback 120, SMA 20, ROC 10
# SENTRYMODE_US10Y_LOOKBACK_DAYS=120
# SENTRYMODE_US10Y_SMA_WINDOW=20
# SENTRYMODE_US10Y_ROC_WINDOW=10

# Regime thresholds and confirmation rules.
# Defaults: green 4.0, red 4.5, ROC warning 0.03, up confirm 2, down confirm 3
# SENTRYMODE_US10Y_GREEN_THRESHOLD=4.0
# SENTRYMODE_US10Y_RED_THRESHOLD=4.5
# SENTRYMODE_US10Y_ROC_WARNING_THRESHOLD=0.03
# SENTRYMODE_US10Y_UP_CONFIRM_DAYS=2
# SENTRYMODE_US10Y_DOWN_CONFIRM_DAYS=3

# Black-swan and SPY confirmation thresholds.
# Defaults: SPY SMA 20, VIX threshold 20.0
# SENTRYMODE_US10Y_SPY_SMA_WINDOW=20
# SENTRYMODE_US10Y_BLACK_SWAN_VIX_THRESHOLD=20.0

# Local JSON file used to persist US10Y state-machine transitions.
# Default: .sentrymode/us10y_state.json
# SENTRYMODE_US10Y_STATE_FILE=.sentrymode/us10y_state.json

# -----------------------------------------------------------------------------
# Example: minimal overrides (uncomment or copy into `.env`)
# -----------------------------------------------------------------------------

SENTRYMODE_BARK_SERVER=
SENTRYMODE_BARK_DEVICE_KEY=
SENTRYMODE_ENABLED_FACTORS=["ahr999","vix","us10y"]
SENTRYMODE_POLL_INTERVAL_SECONDS=60
SENTRYMODE_REPORT_FORMAT=markdown
SENTRYMODE_REPORT_LANGUAGE=en

SENTRYMODE_AHR_RUN_HOUR=9
SENTRYMODE_AHR_RUN_MINUTE=20
SENTRYMODE_AHR_RUN_TIMEZONE=America/New_York

SENTRYMODE_VIX_RUN_HOUR=16
SENTRYMODE_VIX_RUN_MINUTE=5
SENTRYMODE_VIX_RUN_TIMEZONE=America/New_York
SENTRYMODE_VIX_YAHOO_SYMBOL=^VIX
SENTRYMODE_SPY_YAHOO_SYMBOL=SPY
SENTRYMODE_VIX_YAHOO_PERIOD=1y

SENTRYMODE_US10Y_RUN_HOUR=16
SENTRYMODE_US10Y_RUN_MINUTE=10
SENTRYMODE_US10Y_RUN_TIMEZONE=America/New_York
SENTRYMODE_US10Y_SYMBOL=^TNX
SENTRYMODE_US10Y_STATE_FILE=.sentrymode/us10y_state.json

# To enable the Glassnode-backed BTC factor, also set:
# SENTRYMODE_GLASSNODE_API_KEY=your_glassnode_api_key
# SENTRYMODE_ENABLED_FACTORS=["ahr999","vix","us10y","btc_realized_pl_ratio_90d"]

# To enable the AI infrastructure portfolio monitor, also set:
# SENTRYMODE_ENABLED_FACTORS=["ahr999","ai_portfolio","vix","us10y"]
